extensions:
  health_check:
  pprof:
  zpages:

receivers:
  # Local OTLP endpoint (for apps that ship logs directly via OTLP)
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:4317
      http:
        endpoint: 127.0.0.1:4318

  # Systemd/Journald
  journald:
    directory: /var/log/journal
    start_at: end

  # Cloud-init one-off file
  filelog/cloudinit_output:
    include: [/var/log/cloud-init-output.log]
    start_at: beginning
    include_file_path: true
    include_file_name: true
    operators:
      - type: move     # body -> attributes.message, then we restore to body later
        from: body
        to: attributes.message

      - type: router
        routes:
          - output: error_detected
            expr: body matches "(?i)error"
          - output: normal
            expr: "true"

      - id: error_detected
        type: add
        field: attributes.log.level
        value: error

      - id: normal
        type: add
        field: attributes.log.level
        value: info

      - type: add
        field: attributes.log_format
        value: plaintext
      - type: add
        field: attributes.log_source
        value: filelog
      - type: add
        field: attributes.source_type
        value: cloud-init
      - type: add
        field: attributes.service.name
        value: cloud-init
      - type: copy
        from: attributes.service.name
        to: attributes.service_name
      - type: move
        from: attributes.message
        to: body

  # Apt/dpkg logs
  filelog/apt_logs:
    include: [/var/log/apt/*.log, /var/log/dpkg.log]
    start_at: end
    include_file_path: true
    include_file_name: true
    operators:
      - type: move
        from: body
        to: attributes.message

      - type: router
        routes:
          - output: error_detected
            expr: body matches "(?i)\\berror\\b"
          - output: warning_detected
            expr: body matches "(?i)\\bwarn(ing)?\\b"
          - output: normal
            expr: "true"

      - id: error_detected
        type: add
        field: attributes.log.level
        value: error

      - id: warning_detected
        type: add
        field: attributes.log.level
        value: warn

      - id: normal
        type: add
        field: attributes.log.level
        value: info

      - type: add
        field: attributes.log_format
        value: plaintext
      - type: add
        field: attributes.log_source
        value: filelog
      - type: add
        field: attributes.source_type
        value: system-update
      - type: add
        field: attributes.service.name
        value: apt
      - type: copy
        from: attributes.service.name
        to: attributes.service_name
      - type: move
        from: attributes.message
        to: body
  # syslog:
  #   tcp:
  #     listen_address: 0.0.0.0:5514
  #   protocol: rfc5424

processors:
  # Discover cloud + host facts (EC2 hostname, cloud.region, host.id, etc.)
  resourcedetection/ec2:
    detectors: [ec2, system]
    timeout: 2s
    #ec2:
    #  tags: []

  # Your static + templated metadata (resource attributes)
  resource/system_metadata:
    attributes:
      - {key: host.id, value: {{ ansible_board_asset_tag }}, action: upsert}
      - {key: host,    value: {{ hostname_no_instanceid }}, action: upsert}         # short host for labels
      - {key: host.fqdn,    value: {{ ansible_nodename }}, action: upsert}         # short host for labels
      - {key: deployment.environment,     value: {{ platform_env }}, action: upsert}
      - {key: app.name,    value: {{ app_name }}, action: upsert}
      - {key: app.role,    value: {{ app_role }}, action: upsert}
      - {key: project, value: {{ project }}, action: upsert}
      - {key: region,  value: {{ ansible_ec2_instance_identity_document_region }}, action: upsert}

  # Tag the source at the resource-level per pipeline (labels come from resource)
  resource/source_journald:
    attributes:
      - {key: source, value: journald, action: upsert}
  resource/source_file:
    attributes:
      - {key: source, value: filelog, action: upsert}
  # resource/source_syslog:
  #   attributes:
  #     - {key: source, value: syslog, action: upsert}

  # --- Journald-specific extraction (pull fields BEFORE we replace body) ---
  transform/journald_extract:
    log_statements:
      - context: log
        statements:
          - set(attributes["journal.priority"], body["PRIORITY"])          where body["PRIORITY"] != nil
          - set(attributes["journal.user_unit"],     body["_SYSTEMD_USER_UNIT"])     where body["_SYSTEMD_USER_UNIT"] != nil
          - set(attributes["journal.unit"],     body["_SYSTEMD_UNIT"])     where body["_SYSTEMD_UNIT"] != nil
          - set(attributes["logger"],           body["SYSLOG_IDENTIFIER"]) where body["SYSLOG_IDENTIFIER"] != nil
          - set(attributes["exe"],              body["_EXE"])              where body["_EXE"] != nil
          - set(attributes["cmdline"],          body["_CMDLINE"])          where body["_CMDLINE"] != nil
          - set(body, body["MESSAGE"])                                     where body["MESSAGE"] != nil

  # Map journald PRIORITY -> severity_text/number (source of truth)
  transform/severity_from_priority:
    log_statements:
      - context: log
        statements:
          - set(severity_text, "debug") where attributes["journal.priority"] == "7"
          - set(severity_number, 7)     where severity_text == "debug"
          - set(severity_text, "info")  where attributes["journal.priority"] == "6" or attributes["journal.priority"] == "5"
          - set(severity_number, 9)     where severity_text == "info"
          - set(severity_text, "warn")  where attributes["journal.priority"] == "4"
          - set(severity_number, 13)    where severity_text == "warn"
          - set(severity_text, "error") where attributes["journal.priority"] == "3" or attributes["journal.priority"] == "2"
          - set(severity_number, 17)    where severity_text == "error"
          - set(severity_text, "fatal") where attributes["journal.priority"] == "1" or attributes["journal.priority"] == "0"
          - set(severity_number, 24)    where severity_text == "fatal"
          - set(attributes["level"], severity_text) where severity_text != nil

  # Common level normalization for *any* source (filelog/syslog/OTLP)
  transform/level_common:
    log_statements:
      - context: log
        statements:
          - set(attributes["log.level"], ToLowerCase(attributes["log.level"])) where attributes["log.level"] != nil
          - set(attributes["level"],      attributes["log.level"])         where attributes["level"] == nil and attributes["log.level"] != nil
          - set(attributes["level"],      ToLowerCase(attributes["level"]))    where attributes["level"] != nil
          - set(attributes["level"], "warn") where attributes["level"] == "warning"
          - set(attributes["level"], "info") where attributes["level"] == "notice"
          - set(severity_text, attributes["level"]) where severity_text == nil and attributes["level"] != nil
          - set(severity_number, 7)   where severity_number == nil and severity_text == "debug"
          - set(severity_number, 9)   where severity_number == nil and severity_text == "info"
          - set(severity_number, 13)  where severity_number == nil and severity_text == "warn"
          - set(severity_number, 17)  where severity_number == nil and severity_text == "error"
          - set(severity_number, 24)  where severity_number == nil and severity_text == "fatal"

  # Build a single canonical 'service' and clean suffixes; promote to resource.service.name
  transform/service_canonical:
    log_statements:
      - context: log
        statements:
          # precedence: journal.user.unit -> extracted -> existing service.name -> systemd unit -> logger
          - set(attributes["service"], ToLowerCase(attributes["journal.user_unit"]))      where attributes["journal.user_unit"] != nil
          - set(attributes["service"], ToLowerCase(attributes["journal.unit"]))           where attributes["service"] == nil and attributes["journal.unit"] != nil and not IsMatch(attributes["journal.unit"], "^user@\\d+\\.service$")
          - set(attributes["service"], ToLowerCase(attributes["service_name_extracted"])) where attributes["service"] == nil and attributes["service_name_extracted"] != nil
          - set(attributes["service"], ToLowerCase(attributes["journal.unit"]))           where attributes["service"] == nil and attributes["journal.unit"] != nil
          - set(attributes["service"], ToLowerCase(attributes["service.name"]))           where attributes["service"] == nil and attributes["service.name"] != nil
          - set(attributes["service"], ToLowerCase(attributes["logger"]))                 where attributes["service"] == nil and attributes["logger"] != nil

          # trim systemd suffixes
          #- set(attributes["service"], replace_pattern(attributes["service"], "\\.service$", ""))   where attributes["service"] != nil
          #- set(attributes["service"], replace_pattern(attributes["service"], "\\.scope$", ""))     where attributes["service"] != nil
          #- set(attributes["service"], replace_pattern(attributes["service"], "\\.slice\\d+$", "")) where attributes["service"] != nil
          - replace_pattern(attributes["service"], "\\.service$", "")   where attributes["service"] != nil
          - replace_pattern(attributes["service"], "\\.scope$", "")     where attributes["service"] != nil
          - replace_pattern(attributes["service"], "\\.slice\\d+$", "") where attributes["service"] != nil

          # mirror & promote
          - set(attributes["service_name"], attributes["service"])                    where attributes["service"] != nil
          - set(resource.attributes["service.name"], attributes["service"])           where attributes["service"] != nil

  # Resource enrichment & alignment (labels live at resource level for Loki OTLP)
  transform/resource_enrich:
    log_statements:
      - context: resource
        statements:
          # ensure host.name exists (resourcedetection will usually fill this)
          - set(attributes["host.name"], attributes["host"])               where attributes["host.name"] == nil and attributes["host"] != nil
          # mirror cloud.region to short 'region'
          - set(attributes["region"], attributes["cloud.region"])          where attributes["cloud.region"] != nil

  # Optional: prune noise we won't query on
  attributes/prune_noise:
    actions:
      - {action: delete, key: journal.priority}
      - {action: delete, key: journal.unit}
      - {action: delete, key: logfmt}
      - {action: delete, key: metadata}

  batch:

exporters:
  # Loki for log storage
  otlphttp/loki:
    endpoint: "{{ loki_ingestion_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ loki_tenant_name }}"
    tls:
      insecure: false

  # Tempo for trace storage
  otlphttp/tempo:
    endpoint: "{{ tempo_ingestion_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ tempo_tenant_name }}"
    tls:
      insecure: false

  # debug output for troubleshooting
  debug:
    verbosity: detailed

service:
  extensions: [health_check, pprof, zpages]

  pipelines:
    # -------- Journald ----------
    logs/journald:
      receivers: [journald]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_journald
        - transform/journald_extract
        - transform/severity_from_priority
        - transform/level_common
        - transform/service_canonical
        - transform/resource_enrich
        - attributes/prune_noise
        - batch
      exporters: [otlphttp/loki]
      #exporters: [otlphttp/loki,debug]

    # -------- Cloud-init file ----------
    logs/cloudinit_output:
      receivers: [filelog/cloudinit_output]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_file
        - transform/level_common
        - transform/service_canonical
        - transform/resource_enrich
        - attributes/prune_noise
        - batch
      exporters: [otlphttp/loki]
      #exporters: [otlphttp/loki,debug]

    # -------- Apt/Dpkg files ----------
    logs/apt_logs:
      receivers: [filelog/apt_logs]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_file
        - transform/level_common
        - transform/service_canonical
        - transform/resource_enrich
        - attributes/prune_noise
        - batch
      exporters: [otlphttp/loki]
      #exporters: [otlphttp/loki,debug]

    # -------- OTLP logs from apps ----------
    logs/otlp:
      receivers: [otlp]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - transform/level_common
        - transform/service_canonical
        - transform/resource_enrich
        - attributes/prune_noise
        - batch
      exporters: [otlphttp/loki]
      #exporters: [otlphttp/loki,debug]

    # -------- (Optional) Syslog ----------
    # logs/syslog:
    #   receivers: [syslog]
    #   processors:
    #     - resourcedetection/ec2
    #     - resource/system_metadata
    #     - resource/source_syslog
    #     - transform/level_common       # syslog receiver already sets severity; this keeps it aligned
    #     - transform/service_canonical  # service from appname (logger) if present
    #     - transform/resource_enrich
    #     - attributes/prune_noise
    #     - batch
    #   exporters: [otlphttp/loki]
