processors:
  resource/system_metadata:
    attributes:
      - key: instance_id
        value: {{ ansible_board_asset_tag }}
        action: upsert
      - key: instance
        value: {{ hostname_no_instanceid }}
        action: upsert
      - key: env
        value: {{ platform_env }}
        action: upsert
      - key: app_name
        value: {{ app_name }}
        action: upsert
      - key: app_role
        value: {{ app_role }}
        action: upsert
      - key: project
        value: {{ project }}
        action: upsert
      - key: region
        value: {{ ansible_ec2_instance_identity_document_region }}
        action: upsert

  transform/extract_journald_body:
    log_statements:
      - context: log
        statements:
          - set(attributes["log.level"], body["PRIORITY"])
          - set(attributes["service.name"], body["_SYSTEMD_UNIT"])
          - set(attributes["service_name"], attributes["service.name"])
          - set(attributes["exe"], body["_EXE"])
          - set(attributes["cmdline"], body["_CMDLINE"])
          - set(attributes["host"],             body["_HOSTNAME"])
          - set(attributes["app_name"], body["SYSLOG_IDENTIFIER"])
          - set(attributes["log_format"], "journald")
          - set(attributes["log_source"], "journald")
          - set(attributes["source_type"], "system")
          - set(body, body["MESSAGE"])

          - set(attributes["journal.priority"], body["PRIORITY"])            where not IsNil(body["PRIORITY"])
          - set(attributes["journal.unit"],     body["_SYSTEMD_UNIT"])       where not IsNil(body["_SYSTEMD_UNIT"])
          - set(attributes["exe"],              body["_EXE"])                where not IsNil(body["_EXE"])
          - set(attributes["cmdline"],          body["_CMDLINE"])            where not IsNil(body["_CMDLINE"])
          - set(attributes["logger"],           body["SYSLOG_IDENTIFIER"])   where not IsNil(body["SYSLOG_IDENTIFIER"])
          - set(attributes["log_format"],       "journald")
          - set(attributes["log_source"],       "journald")
          - set(attributes["source_type"],      "system")
          - set(body, body["MESSAGE"])   



  transform/map_log_level:
    log_statements:
      - context: log
        statements:
          - set(attributes["log.level"], "emergency") where attributes["log.level"] == "0"
          - set(attributes["log.level"], "alert")     where attributes["log.level"] == "1"
          - set(attributes["log.level"], "critical")  where attributes["log.level"] == "2"
          - set(attributes["log.level"], "error")     where attributes["log.level"] == "3"
          - set(attributes["log.level"], "warning")   where attributes["log.level"] == "4"
          - set(attributes["log.level"], "notice")    where attributes["log.level"] == "5"
          - set(attributes["log.level"], "info")      where attributes["log.level"] == "6"
          - set(attributes["log.level"], "debug")     where attributes["log.level"] == "7"
          - set(attributes["level"], attributes["log.level"])

  transform/normalize_log_level:
    log_statements:
      - context: log
        statements:
          - set(attributes["log.level"], "warn") where attributes["log.level"] == "warning"
          - set(attributes["log.level"], "info") where attributes["log.level"] == "notice"
          - set(attributes["level"], attributes["log.level"])

  transform/clean_service_name:
    log_statements:
      - context: log
        statements:
          - replace_pattern(attributes["service_name"], "@.*", "")
          - replace_pattern(attributes["service_name"], "\\.service$", "")
          - replace_pattern(attributes["service_name"], "\\.scope$", "")
          - replace_pattern(attributes["service_name"], "\\.slice\\d+$", "")

  batch:

exporters:
  otlphttp/loki:
    endpoint: "{{ loki_ingestion_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ loki_tenant_name }}"
    tls:
      insecure: false

  otlphttp/tempo:
    endpoint: "{{ tempo_ingestion_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ tempo_tenant_name }}"
    tls:
      insecure: false

  debug:
    verbosity: detailed

service:
  extensions:
    - health_check
    - pprof
    - zpages

  pipelines:
    logs:
      receivers:
        - journald
      processors:
        - resource/system_metadata
        - transform/extract_journald_body
        - transform/map_log_level
        - transform/normalize_log_level
        - transform/clean_service_name
        - batch
      exporters:
        - otlphttp/loki
        #- debug

    logs/cloudinit_output:
      receivers:
        - filelog/cloudinit_output
      processors:
        - resource/system_metadata
        - transform/normalize_log_level
        - batch
      exporters:
        - otlphttp/loki
        #- debug

    logs/apt_logs:
      receivers:
        - filelog/apt_logs
      processors:
        - resource/system_metadata
        - transform/normalize_log_level
        - batch
      exporters:
        - otlphttp/loki
        #- debug
