extensions:
  health_check:
  pprof:
  zpages:

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:4317
      http:
        endpoint: 127.0.0.1:4318

  journald:
    directory: /var/log/journal
    start_at: end

  filelog/cloudinit_output:
    include:
      - /var/log/cloud-init-output.log
    start_at: beginning
    include_file_path: true
    include_file_name: true
    operators:
      - type: move
        from: body
        to: attributes.message

      - type: router
        routes:
          - output: error_detected
            expr: body matches "(?i)error"
          - output: normal
            expr: "true"

      - id: error_detected
        type: add
        field: attributes.log.level
        value: error

      - id: error_detected_copy
        type: copy
        from: attributes.log.level
        to: attributes.level

      - id: normal
        type: add
        field: attributes.log.level
        value: info

      - id: normal_copy
        type: copy
        from: attributes.log.level
        to: attributes.level

      - type: add
        field: attributes.log_format
        value: plaintext
      - type: add
        field: attributes.log_source
        value: filelog
      - type: add
        field: attributes.source_type
        value: cloud-init
      - type: add
        field: attributes.service.name
        value: cloud-init
      - type: copy
        from: attributes.service.name
        to: attributes.service_name
      - type: move
        from: attributes.message
        to: body

  filelog/apt_logs:
    include:
      - /var/log/apt/*.log
      - /var/log/dpkg.log
    start_at: end
    include_file_path: true
    include_file_name: true
    operators:
      - type: move
        from: body
        to: attributes.message

      - type: router
        routes:
          - output: error_detected
            expr: body matches "(?i)error"
          - output: warning_detected
            expr: body matches "(?i)warn"
          - output: normal
            expr: "true"

      - id: error_detected
        type: add
        field: attributes.log.level
        value: error

      - id: warning_detected
        type: add
        field: attributes.log.level
        value: warn

      - id: normal
        type: add
        field: attributes.log.level
        value: info

      - type: copy
        from: attributes.log.level
        to: attributes.level

      - type: add
        field: attributes.log_format
        value: plaintext
      - type: add
        field: attributes.log_source
        value: filelog
      - type: add
        field: attributes.source_type
        value: system-update
      - type: add
        field: attributes.service.name
        value: apt
      - type: copy
        from: attributes.service.name
        to: attributes.service_name
      - type: move
        from: attributes.message
        to: body

