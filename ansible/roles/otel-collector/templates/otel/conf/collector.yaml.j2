extensions:
  health_check:
  pprof:
  zpages:

receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 127.0.0.1:4317
      http:
        endpoint: 127.0.0.1:4318

  journald:
    directory: /var/log/journal
    start_at: end
    operators:
      - id: logger-from-user-unit
        type: add
        if: 'body["_SYSTEMD_USER_UNIT"] != nil'
        field: attributes["logger_raw"]
        value: EXPR(body["_SYSTEMD_USER_UNIT"])

      - id: logger-from-unit
        type: add
        if: 'attributes["logger_raw"] == nil && body["_SYSTEMD_UNIT"] != nil'
        field: attributes["logger_raw"]
        value: EXPR(body["_SYSTEMD_UNIT"])

      - id: logger-trim-suffixes
        type: regex_parser
        if: 'attributes["logger_raw"] != nil'
        parse_from: attributes["logger_raw"]
        regex: '^(?P<logger_name_canonical>user@\d+|[^@]+?)(?:@.*)?(?:\.service|\.scope|\.slice\d+)?$'

      - id: logger-to-attribute
        type: add
        if: 'attributes["logger_name_canonical"] != nil'
        field: attributes["logger"]
        value: EXPR(attributes["logger_name_canonical"])

  filelog/apt_logs:
    include: [/var/log/apt/*.log, /var/log/dpkg.log]
    start_at: end
    include_file_path: true
    include_file_name: true
    operators:
      - type: move
        from: body
        to: attributes.message

      - type: router
        routes:
          - output: error_detected
            expr: body matches "(?i)\\berror\\b"
          - output: warning_detected
            expr: body matches "(?i)\\bwarn(ing)?\\b"
          - output: normal
            expr: "true"

      - id: error_detected
        type: add
        field: attributes.log.level
        value: error

      - id: warning_detected
        type: add
        field: attributes.log.level
        value: warn

      - id: normal
        type: add
        field: attributes.log.level
        value: info

      - type: add
        field: attributes.log_format
        value: plaintext
      - type: add
        field: attributes.log_source
        value: filelog
      - type: add
        field: attributes.source_type
        value: system-update
      - type: add
        field: attributes.logger.name
        value: apt
      - type: copy
        from: attributes.logger.name
        to: attributes.logger_name
      - type: move
        from: attributes.message
        to: body

processors:
  resourcedetection/ec2:
    detectors: [ec2, system]
    timeout: 2s

  # Canonical identity + inventory metadata (RESOURCE attributes)
  resource/system_metadata:
    attributes:
      - {key: company, value: {{ company_name }}, action: upsert}
      - {key: project, value: {{ project }}, action: upsert}

      # Environment (new meaning) + compatibility alias for existing Loki queries
      - {key: deployment.environment.name, value: {{ platform_env }}, action: upsert}
      # - {key: env, value: {{ platform_env }}, action: upsert}

      # Account identity
      - {key: phxi.account.name, value: {{ account_name }}, action: upsert}
      - {key: phxi.account.label, value: {{ account_name }}-{{ platform_env }}, action: upsert}

      # Service identity (your new plan)
      - {key: service.namespace, value: {{ namespace }}, action: upsert}
      - {key: service.name, value: {{ service_name }}-{{ service_component }}, action: upsert}
      - {key: phxi.service.name, value: {{ service_name }}, action: upsert}
      - {key: phxi.service.component, value: {{ service_component }}, action: upsert}

      # Instance/host inventory
      - {key: host.id, value: {{ ansible_ec2_instance_identity_document_instanceid }}, action: upsert}
      - {key: host.ip, value: {{ ansible_default_ipv4.address }}, action: upsert}
      - {key: host.type, value: {{ ansible_ec2_instance_identity_document_instancetype }}, action: upsert}
      - {key: host.fqdn, value: {{ hostname_no_instanceid }}.{{ hosted_zone_name }}, action: upsert}
      - {key: node, value: {{ hostname_no_instanceid }}, action: upsert}
      # - {key: region, value: {{ ansible_ec2_instance_identity_document_region }}, action: upsert}

      - {key: cloud.region, value: {{ ansible_ec2_instance_identity_document_region }}, action: upsert}
      - {key: cloud.availability_zone, value: {{ ansible_ec2_instance_identity_document_availabilityzone }}, action: upsert}
      - {key: cloud.account.id, value: {{ ansible_ec2_identity_credentials_ec2_info_accountid }}, action: upsert}

  resource/source_journald:
    attributes:
      - {key: source, value: journald, action: upsert}
  resource/source_file:
    attributes:
      - {key: source, value: filelog, action: upsert}
  resource/source_otlp:
    attributes:
      - {key: source, value: otlp, action: upsert}

  transform/journald_extract:
    log_statements:
      - context: log
        statements:
          - set(log.attributes["journal.priority"], log.body["PRIORITY"]) where log.body["PRIORITY"] != nil
          - set(log.attributes["journal.user_unit"], log.body["_SYSTEMD_USER_UNIT"]) where log.body["_SYSTEMD_USER_UNIT"] != nil
          - set(log.attributes["journal.unit"], log.body["_SYSTEMD_UNIT"]) where log.body["_SYSTEMD_UNIT"] != nil
          - set(log.attributes["journal.identifier"], ToLowerCase(log.body["SYSLOG_IDENTIFIER"])) where log.body["SYSLOG_IDENTIFIER"] != nil
          - set(log.attributes["exe"], log.body["_EXE"]) where log.body["_EXE"] != nil
          - set(log.attributes["cmdline"], log.body["_CMDLINE"]) where log.body["_CMDLINE"] != nil
          - set(log.body, log.body["MESSAGE"]) where log.body["MESSAGE"] != nil

  transform/journald_parse_json:
    error_mode: ignore
    log_statements:
      - context: log
        statements:
          - set(log.cache["parsed"], ParseJSON(log.body))
            where IsString(log.body) and Substring(log.body, 0, 1) == "{"
          - set(log.attributes["level"], ToLowerCase(log.cache["parsed"]["level"]))
            where log.cache["parsed"]["level"] != nil
          - set(log.attributes["msg"], log.cache["parsed"]["msg"])
            where log.attributes["msg"] == nil and log.cache["parsed"]["msg"] != nil
          - set(log.attributes["caller"], log.cache["parsed"]["caller"])
            where log.attributes["caller"] == nil and log.cache["parsed"]["caller"] != nil
          - delete_key(log.cache, "parsed")
            where log.cache["parsed"] != nil

  transform/level_common:
    log_statements:
      - context: log
        statements:
          - set(log.attributes["log.level"], ToLowerCase(log.attributes["log.level"])) where log.attributes["log.level"] != nil
          - set(log.attributes["level"], log.attributes["log.level"]) where log.attributes["level"] == nil and log.attributes["log.level"] != nil
          - set(log.attributes["level"], ToLowerCase(log.attributes["detected_level"])) where log.attributes["level"] == nil and log.attributes["detected_level"] != nil
          - set(log.attributes["level"], "warn") where log.attributes["level"] == "warning"
          - set(log.attributes["level"], "info") where log.attributes["level"] == "notice" or log.attributes["level"] == "unknown"
          - set(log.severity_text, log.attributes["level"]) where log.severity_text == nil and log.attributes["level"] != nil
          - set(log.severity_number, 7)  where log.severity_number == nil and log.severity_text == "debug"
          - set(log.severity_number, 9)  where log.severity_number == nil and log.severity_text == "info"
          - set(log.severity_number, 13) where log.severity_number == nil and log.severity_text == "warn"
          - set(log.severity_number, 17) where log.severity_number == nil and log.severity_text == "error"
          - set(log.severity_number, 24) where log.severity_number == nil and log.severity_text == "fatal"

  transform/level_journald:
    log_statements:
      - context: log
        statements:
          - set(log.attributes["level"], ToLowerCase(log.attributes["level"])) where log.attributes["level"] != nil
          - set(log.attributes["level"], "warn") where log.attributes["level"] == "warning"
          - set(log.attributes["level"], "info") where log.attributes["level"] == "notice" or log.attributes["level"] == "unknown"

          - set(log.attributes["level"], "debug") where log.attributes["level"] == nil and log.attributes["journal.priority"] == "7"
          - set(log.attributes["level"], "info")  where log.attributes["level"] == nil and (log.attributes["journal.priority"] == "6" or log.attributes["journal.priority"] == "5")
          - set(log.attributes["level"], "warn")  where log.attributes["level"] == nil and log.attributes["journal.priority"] == "4"
          - set(log.attributes["level"], "error") where log.attributes["level"] == nil and (log.attributes["journal.priority"] == "3" or log.attributes["journal.priority"] == "2")
          - set(log.attributes["level"], "fatal") where log.attributes["level"] == nil and (log.attributes["journal.priority"] == "1" or log.attributes["journal.priority"] == "0")
          - set(log.attributes["level"], "info")  where log.attributes["level"] == nil

          - set(log.severity_text, log.attributes["level"]) where log.attributes["level"] != nil
          - set(log.severity_number, 7)  where log.severity_text == "debug"
          - set(log.severity_number, 9)  where log.severity_text == "info"
          - set(log.severity_number, 13) where log.severity_text == "warn"
          - set(log.severity_number, 17) where log.severity_text == "error"
          - set(log.severity_number, 24) where log.severity_text == "fatal"

  attributes/prune_noise_logs:
    actions:
      - {action: delete, key: journal.priority}
      - {action: delete, key: journal.unit}
      - {action: delete, key: metadata}
      - {action: delete, key: logger_raw}
      - {action: delete, key: logger_name_canonical}

  batch:

exporters:
  otlphttp/loki:
    endpoint: "{{ logs_push_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ loki_tenant_name }}"
    tls:
      insecure: false

  otlphttp/tempo:
    endpoint: "{{ traces_push_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ tempo_tenant_name }}"
    tls:
      insecure: false

  debug:
    verbosity: detailed

service:
  extensions: [health_check, pprof, zpages]

  pipelines:
    logs/journald:
      receivers: [journald]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_journald
        - transform/journald_extract
        - transform/journald_parse_json
        - transform/level_journald
        - attributes/prune_noise_logs
        - batch
      exporters: [otlphttp/loki]

    logs/apt_logs:
      receivers: [filelog/apt_logs]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_file
        - transform/level_common
        - attributes/prune_noise_logs
        - batch
      exporters: [otlphttp/loki]

    logs/otlp:
      receivers: [otlp]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_otlp
        - transform/level_common
        - batch
      exporters: [otlphttp/loki]

    traces/otlp:
      receivers: [otlp]
      processors:
        - resourcedetection/ec2
        - resource/system_metadata
        - resource/source_otlp
        - batch
      exporters: [otlphttp/tempo]
