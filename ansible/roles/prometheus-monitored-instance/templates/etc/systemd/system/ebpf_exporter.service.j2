[Unit]
Description=Cloudflare ebpf_exporter for efficient ebpf kernel hook metrics collection
Requires=network.target
After=network.target
StartLimitIntervalSec=0

[Service]
WorkingDirectory={{ ebpf_exporter_base_directory }}
User=root
Group=root
ExecStart={{ ebpf_exporter_base_directory }}/bin/ebpf_exporter {{ ebpf_exporter_flags }}
#StandardOutput=append:/var/log/{{ ebpf_exporter_systemd_service_name }}.log
#StandardError=append:/var/log/{{ ebpf_exporter_systemd_service_name }}.log
KillMode=mixed
TimeoutSec=60
Type=simple
#LimitNOFILE=100000
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
