[Unit]
Description=Provides web frontend for LinnemanLabs Trust
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=0

[Service]
WorkingDirectory=/var/lib/{{ trustportal_system_user }}
User={{ trustportal_system_user }}
Group={{ trustportal_system_user }}
EnvironmentFile=/etc/trustportal/trustportal-server.env
ExecStart=/opt/trustportal/bin/trustportal-server
# StandardOutput=append:/var/log/{{ trustportal_systemd_service_name }}.log
# StandardError=append:/var/log/{{ trustportal_systemd_service_name }}.log
StandardOutput=journal
StandardError=journal
KillMode=mixed
TimeoutSec=60
Type=notify
NotifyAccess=main
TimeoutStartSec=30
LimitNOFILE=100000
Restart=on-failure
RestartSec=5s

UMask=0077

# process hardening
NoNewPrivileges=true
PrivateDevices=yes
DevicePolicy=closed
CapabilityBoundingSet=
AmbientCapabilities=
RestrictSUIDSGID=yes
ProtectProc=invisible
ProcSubset=pid
LockPersonality=yes
MemoryDenyWriteExecute=yes
RestrictNamespaces=yes
RestrictRealtime=yes
SystemCallArchitectures=native

# fs hardening
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
StateDirectory={{ trustportal_system_user }}
# covered by ProtectSystem=strict already
# ReadOnlyPaths=/opt/trustportal
ReadWritePaths=/var/lib/{{ trustportal_system_user }} /run

# kernel/mem hardening
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes

# network hardening
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

[Install]
WantedBy=multi-user.target
