target: {{ mimir_role }}
multitenancy_enabled: true
usage_stats:
  enabled: false

common:
  storage:
    backend: s3
    s3:
      region: {{ ansible_ec2_instance_identity_document_region }}
      bucket_name: {{ mimir_s3_bucket_name }}

server:
  grpc_listen_port: {{ mimir_grpc_tcp_port }}
  grpc_server_keepalive_time: 5m
  http_listen_port: {{ mimir_http_tcp_port }}
  http_tls_config:
    cert_file: /home/{{ mimir_system_user }}/conf/ssl/cert.pem
    key_file: /home/{{ mimir_system_user }}/conf/ssl/cert.key
  log_format: json
  #log_format: logfmt
  log_level: info
  register_instrumentation: true

distributor:
  # enabling this will elect a prometheus leader and drop requests from the other HA prometheus in the pair until the leader completely stops posting
  # leaving disabled will let the last prometheus to record a metric per scrape interval block as the winner and accept metrics from both
  # re-enabling this. data is consistent after compaction but currently queries only go to store-gateway after 12h and seeing slightly different data when
  # charts refresh for the first 12h is probably a poor user experience
  ha_tracker:
    enable_ha_tracker: true
    #enable_for_all_users: true 
    kvstore:
      store: memberlist
    ha_tracker_update_timeout: 15s
    ha_tracker_update_timeout_jitter_max: 5s
    ha_tracker_failover_timeout: 30s
  #ha_tracker:
  #  enable_ha_tracker: true
  #  kvstore:
  #   store: etcd
  #   prefix: mimir-ha-tracker/
  #   etcd:
  #     endpoints:
  #       - monitoring-etcd-2a.{{ hosted_zone_name }}:2379
  #       - monitoring-etcd-2b.{{ hosted_zone_name }}:2379
  #       - monitoring-etcd-2c.{{ hosted_zone_name }}:2379
  #  ha_tracker_update_timeout: 12s
  #  ha_tracker_update_timeout_jitter_max: 2s
  #  ha_tracker_failover_timeout: 20s
  ring:
    kvstore:
      store: memberlist
  #tracing_enabled: false
  #tracing_endpoint:

ingester:
  ring:
    kvstore:
      store: memberlist
    replication_factor: {{ mimir_replication_factor }}
    instance_availability_zone: {{ ansible_ec2_instance_identity_document_availabilityzone }}
    unregister_on_shutdown: true
    zone_awareness_enabled: true
  partition_ring:
    kvstore:
      store: memberlist
  instance_limits:
    #max_inflight_push_requests: 30000
    max_inflight_push_requests: 8192
  error_sample_rate: 0

ingester_client:
  grpc_client_config:
    max_send_msg_size: 104857600
    max_recv_msg_size: 104857600
    grpc_compression: snappy

querier:
  # default: 12h
  query_store_after: 12h
  #query_engine: prometheus
  # testing performance but this is an experimental feature currently
  query_engine: mimir
  enable_query_engine_fallback: true
  max_concurrent: 20
  # 2m default timeout
  timeout: 60s
  #prefer_availability_zone: {{ ansible_ec2_instance_identity_document_availabilityzone }}

frontend:
  max_outstanding_per_tenant: 10000
  log_queries_longer_than: 3s
  query_result_response_format: protobuf
  grpc_client_config:
    max_send_msg_size: 104857600
    max_recv_msg_size: 104857600
    grpc_compression: snappy
  results_cache:
    backend: memcached
    memcached:
      addresses: mimir-memcached-2a.{{ hosted_zone_name }}:11211,mimir-memcached-2b.{{ hosted_zone_name }}:11211,mimir-memcached-2c.{{ hosted_zone_name }}:11211
      timeout: 200ms
      connect_timeout: 200ms
      #max_item_size: 2097152
      max_item_size: 8388608
    compression: snappy
  cache_results: true
  parallelize_shardable_queries: true
  
query_scheduler:
  max_outstanding_requests_per_tenant: 10000
  service_discovery_mode: ring
  #service_discovery_mode: dns
  ring:
    kvstore:
      store: memberlist
    heartbeat_period: 15s
    heartbeat_timeout: 30s
  grpc_client_config:
    max_send_msg_size: 104857600
    max_recv_msg_size: 104857600
    grpc_compression: snappy

frontend_worker:
  # if we change to dns service_discovery_mode for query_scheduler we need to define this as a hostname that resolves to all query-scheduler instances
  #scheduler_address:
  grpc_client_config:
    max_send_msg_size: 104857600
    max_recv_msg_size: 104857600
    grpc_compression: snappy
  query_scheduler_grpc_client_config:
    max_send_msg_size: 104857600
    max_recv_msg_size: 104857600
    grpc_compression: snappy

limits:
  # this elects a leader prometheus and drops samples from the other until a 30s timeout and new leader election
  # by leaving disabled all samples are accepted and the last to be received per time series block is kept
  accept_ha_samples: true
  # reject any samples with a timestamp in the future that varies from our clock by more than this amount
  creation_grace_period: 5m
  ingestion_rate: 100000
  ingestion_burst_factor: 2
  #ingestion_burst_size: 20000
  #ha_cluster_label: cluster
  #ha_replica_label: __replica__
  # labels to drop from all ingested samples, list of strings
  #drop_labels: 
  max_cache_freshness: 10m
  max_label_name_length: 1024
  max_label_value_length: 2048
  max_label_names_per_series: 30
  max_label_names_per_info_series: 80
  max_metadata_length: 1024
  native_histograms_ingestion_enabled: true
  # reject any samples with a timestamp in the past that varies from our clock by more than this amount
  #past_grace_period: 5m
  # track time series per tenant, list of strings mapping
  #active_series_custom_trackers:
  # disabling so they get outright rejected instead so we can see the error and know
  reduce_native_histogram_over_max_buckets: false
  request_rate: 0
  request_burst_size: 0
  results_cache_ttl: 1w
  #otel_metric_suffixes_enabled: false
  # otel resource attributes to promote to labels
  #promote_otel_resource_attributes: 
  max_global_series_per_user: 2000000


blocks_storage:
  backend: s3
  storage_prefix: mimir
  s3:
    endpoint: s3.amazonaws.com
    region: {{ ansible_ec2_instance_identity_document_region }}
    bucket_name: {{ mimir_s3_bucket_name }}
    insecure: false
    http:
      idle_conn_timeout: 90s
      response_header_timeout: 60s
      expect_continue_timeout: 5s
  bucket_store:
    sync_interval: 10m
    max_concurrent: 200
    #index_cache:
    #  #backend: memcached
    #  backend: inmemory
    #  inmemory:
    #    #max_size_bytes: 2147483648
    #    #max_size_bytes: 1073741824
    #    max_size_bytes: 10737418240
    index_cache:
      backend: memcached
      memcached:
        addresses: mimir-memcached-2a.{{ hosted_zone_name }}:11211,mimir-memcached-2b.{{ hosted_zone_name }}:11211,mimir-memcached-2c.{{ hosted_zone_name }}:11211
        timeout: 200ms
        connect_timeout: 200ms
        max_item_size: 8388608
    chunks_cache:
      backend: memcached
      memcached:
        addresses: mimir-memcached-2a.{{ hosted_zone_name }}:11211,mimir-memcached-2b.{{ hosted_zone_name }}:11211,mimir-memcached-2c.{{ hosted_zone_name }}:11211
        timeout: 200ms
        connect_timeout: 200ms
        max_item_size: 8388608
    metadata_cache:
      backend: memcached
      memcached:
        addresses: mimir-memcached-2a.{{ hosted_zone_name }}:11211,mimir-memcached-2b.{{ hosted_zone_name }}:11211,mimir-memcached-2c.{{ hosted_zone_name }}:11211
        timeout: 200ms
        connect_timeout: 200ms
        max_item_size: 8388608
    bucket_index:
      idle_timeout: 24h
      #idle_timeout: 1h
    # default: 10h
    ignore_blocks_within: 10h
    index_header:
      max_idle_file_handles: 1
      eager_loading_startup_enabled: true
      lazy_loading_enabled: false
  tsdb:
    # this directory should persist between reboots on ingesters
    # if we properly flush incomplete blocks before shutdown non-persistent disks shouldnt be an issue
    dir: ./tsdb/
    retention_period: 13h
    close_idle_tsdb_timeout: 13h
    ship_interval: 1m
    head_compaction_interval: 1m
    flush_blocks_on_shutdown: true

compactor:
  block_ranges:
    - 2h0m0s
    - 12h0m0s
    - 24h0m0s
  # number of goroutines to use for transporting blocks for compaction
  block_sync_concurrency: 8
  # number of goroutines to use for syncing block meta files from s3
  meta_sync_concurrency: 20
  compaction_interval: 1h
  first_level_compaction_wait_period: 25m
  cleanup_interval: 15m
  deletion_delay: 24h
  tenant_cleanup_delay: 6h
  sharding_ring:
    kvstore:
      store: memberlist

store_gateway:
  sharding_ring:
    kvstore:
      store: memberlist
    zone_awareness_enabled: true
    instance_availability_zone: {{ ansible_ec2_instance_identity_document_availabilityzone }}

memberlist:
  join_members:
    - mimir-compactor-2a.{{ hosted_zone_name }}
    - mimir-compactor-2b.{{ hosted_zone_name }}
    - mimir-compactor-2c.{{ hosted_zone_name }}
    - mimir-distributor-2a.{{ hosted_zone_name }}
    - mimir-distributor-2b.{{ hosted_zone_name }}
    - mimir-distributor-2c.{{ hosted_zone_name }}
    - mimir-ingester-2a.{{ hosted_zone_name }}
    - mimir-ingester-2b.{{ hosted_zone_name }}
    - mimir-ingester-2c.{{ hosted_zone_name }}
    - mimir-querier-2a.{{ hosted_zone_name }}
    - mimir-querier-2b.{{ hosted_zone_name }}
    - mimir-querier-2c.{{ hosted_zone_name }}
    - mimir-query-frontend-2a.{{ hosted_zone_name }}
    - mimir-query-frontend-2b.{{ hosted_zone_name }}
    - mimir-query-frontend-2c.{{ hosted_zone_name }}
    - mimir-query-scheduler-2a.{{ hosted_zone_name }}
    - mimir-query-scheduler-2b.{{ hosted_zone_name }}
    - mimir-query-scheduler-2c.{{ hosted_zone_name }}
    - mimir-store-gateway-2a.{{ hosted_zone_name }}
    - mimir-store-gateway-2b.{{ hosted_zone_name }}
    - mimir-store-gateway-2c.{{ hosted_zone_name }}
  bind_port: 7946
  abort_if_cluster_join_fails: true
