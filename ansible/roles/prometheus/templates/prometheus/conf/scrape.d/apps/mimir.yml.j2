scrape_configs:

  - job_name: 'mimir/compactor'
    metrics_path: /metrics
    scheme: https
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
          - mimir-compactor-2a.{{ hosted_zone_name }}:8443
          - mimir-compactor-2b.{{ hosted_zone_name }}:8443
          - mimir-compactor-2c.{{ hosted_zone_name }}:8443
        labels:
          cluster: "{{ company_name }}-{{ platform_env }}-{{ ansible_ec2_instance_identity_document_region }}"
          namespace: mimir
          service_name: mimir
          service_role: compactor
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: host_fqdn
        replacement: '$1'
      - source_labels: [__address__]
        regex: "([^.]*)\\.?.*"
        target_label: node

