scrape_configs:

  - job_name: 'alertmanager/alertmanager'
    metrics_path: /metrics
    scheme: https
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
          - alertmanager-2a.{{ hosted_zone_name }}:9093
          - alertmanager-2b.{{ hosted_zone_name }}:9093
          - alertmanager-2c.{{ hosted_zone_name }}:9093
        labels:
          cluster: "{{ company_name }}-{{ platform_env }}-{{ ansible_ec2_instance_identity_document_region }}"
          namespace: alertmanager
          service_name: alertmanager
          service_role: alertmanager
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: host_fqdn
        replacement: '$1'
      - source_labels: [__address__]
        regex: "([^.]*)\\.?.*"
        target_label: node
