scrape_configs:

  - job_name: 'tempo/compactor'
    metrics_path: /metrics
    scheme: https
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
          - tempo-compactor-2a.{{ hosted_zone_name }}:8443
          - tempo-compactor-2b.{{ hosted_zone_name }}:8443
          - tempo-compactor-2c.{{ hosted_zone_name }}:8443
        labels:
          service_namespace: observability
          service_name: tempo-compactor
          phxi_service_name: tempo
          phxi_service_component: compactor
          namespace: tempo
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: host_fqdn
        replacement: '$1'
      - source_labels: [__address__]
        regex: "([^.]*)\\.?.*"
        target_label: node

