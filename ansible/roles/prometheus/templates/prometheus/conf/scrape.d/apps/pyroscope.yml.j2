scrape_configs:

  - job_name: 'pyroscope/compactor'
    metrics_path: /metrics
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
          - pyroscope-compactor-2a.{{ hosted_zone_name }}:8443
          - pyroscope-compactor-2b.{{ hosted_zone_name }}:8443
          - pyroscope-compactor-2c.{{ hosted_zone_name }}:8443
        labels:
          cluster: "{{ company_name }}-{{ platform_env }}-{{ ansible_ec2_instance_identity_document_region }}"
          namespace: pyroscope
          service_name: pyroscope
          service_role: compactor
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: host_fqdn
        replacement: '$1'
      - source_labels: [__address__]
        regex: "([^.]*)\\.?.*"
        target_label: node

