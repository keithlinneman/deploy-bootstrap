scrape_configs:
  - job_name: 'grafana/server'
    metrics_path: /metrics
    scrape_interval: 15s
    scrape_timeout: 10s
    scheme: https
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
          - grafana-2a.{{ hosted_zone_name }}:8443
          - grafana-2b.{{ hosted_zone_name }}:8443
        labels:
          cluster: "{{ company_name }}-{{ platform_env }}-{{ ansible_ec2_instance_identity_document_region }}"
          service_namespace: observability
          service_name: grafana-server
          phxi_service_name: grafana
          phxi_service_component: server

    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: host_fqdn
        replacement: '$1'
      - source_labels: [__address__]
        regex: "([^.]*)\\.?.*"
        target_label: node