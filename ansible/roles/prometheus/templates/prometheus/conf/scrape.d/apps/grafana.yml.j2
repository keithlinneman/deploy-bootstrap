scrape_configs:
  - job_name: 'grafana/grafana'
    metrics_path: /metrics
    scheme: https
    tls_config:
      insecure_skip_verify: true
    static_configs:
      - targets:
          - grafana-2a.{{ hosted_zone_name }}:9093
          - grafana-2b.{{ hosted_zone_name }}:9093
        labels:
          cluster: "{{ company_name }}-{{ platform_env }}-{{ ansible_ec2_instance_identity_document_region }}"
          namespace: grafana
          service_name: grafana
          service_role: grafana
    relabel_configs:
      - source_labels: [__address__]
        regex: '([^:]+):.*'
        target_label: host_fqdn
        replacement: '$1'
      - source_labels: [__address__]
        regex: "([^.]*)\\.?.*"
        target_label: node