runtime:
  # https://tip.golang.org/doc/gc-guide#GOGC
  #gogc: 75

# Global configuration
global:
  # How often to collect metrics
  scrape_interval:     {{ prometheus_scrape_interval }}
  scrape_timeout:      {{ prometheus_scrape_timeout }}
  # How often to evaluate metrics vs alert rules
  evaluation_interval: {{ prometheus_scrape_interval }}

  # Attach these labels to any time series or alerts when communicating with
  # external systems (federation, remote storage, Alertmanager).
  external_labels:
    cluster: "{{ company_name }}-{{ platform_env }}-{{ region_short_name[ansible_ec2_instance_identity_document_region] }}"
    cloud_region: "{{ ansible_ec2_instance_identity_document_region }}"
    deployment_environment_name: "{{ platform_env }}"
    company: "{{ company_name }}"
    phxi_account_name: "{{ account_name }}"
    phxi_account_label: "{{ account_name }}-{{ platform_env }}"
    #__replica__: "{{ ansible_ec2_instance_identity_document_availabilityzone }}"
    __replica__: "{{ region_short_name[ansible_ec2_instance_identity_document_region] }}-{{ ansible_ec2_instance_identity_document_availabilityzone.split('-')[-1] }}"
    monitor: "prometheus-ha-{{ region_short_name[ansible_ec2_instance_identity_document_region] }}"

  #scrape_failure_log_file: 
  # The max number of samples that can be returned per scrape or it will be rejected
  #sample_limit: 
  # The max number of labels that can be returned per scrape or it will be rejected
  #label_limit: 
  ##metrics_path: "/metrics"
  metric_name_validation_scheme: utf8

# Alertmanager configuration
alerting:
  alert_relabel_configs:
    - action: labeldrop
      regex:  '__replica__'
  alertmanagers:
    - scheme: https
      static_configs:
        #- targets: ['alertmanager-2a.{{ hosted_zone_name }}:9093', 'alertmanager-2b.{{ hosted_zone_name }}:9093', 'alertmanager-2c.{{ hosted_zone_name }}:9093']
        - targets:
{% for endpoint in alerts_push_endpoints.split(',') %}
            - '{{ endpoint }}'
{% endfor %}
      tls_config:
        insecure_skip_verify: true

# Alerting rules loaded once, evaluated every 'evaluation_interval'.
rule_files:
  - /home/{{ prometheus_system_user }}/conf/rules/recording/apps/*.yml
  - /home/{{ prometheus_system_user }}/conf/rules/recording/node/*.yml
  - /home/{{ prometheus_system_user }}/conf/rules/alerting/apps/*.yml
  - /home/{{ prometheus_system_user }}/conf/rules/alerting/node/*.yml

scrape_config_files:
  - /home/{{ prometheus_system_user }}/conf/scrape.d/apps/*.yml
  - /home/{{ prometheus_system_user }}/conf/scrape.d/node/*.yml
  - /home/{{ prometheus_system_user }}/conf/scrape.d/blackbox/*.yml

# For storage in mimir
remote_write:
  - url: "{{ metrics_push_endpoint }}"
    headers:
      X-Scope-OrgID: "{{ prometheus_tenant_name }}"
    #name: mimir-{{ platform_env }}
    name: mimir
    send_exemplars: true
    remote_timeout: 30s
    queue_config:
      batch_send_deadline: 2s
      max_samples_per_send: 2000
      # attempting a really high value that should work out to around 2gb memory max
      # will give mimir maximum time to recover if it is ever down without having to manually feed data in from prometheus
      # capacity: 25000
      # capacity: 134217728
      # ok adjusted to use ~1gb max since i run on right-sized instances
      capacity: 67217728
      max_shards: 9
    #write_relabel_configs:

