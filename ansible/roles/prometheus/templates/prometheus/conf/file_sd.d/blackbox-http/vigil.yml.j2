- targets:
    - https://vigil.{{ hosted_zone_name }}/-/ready
  labels:
    check_type: health
    probe_kind: endpoint
    deployment_environment_name: {{ platform_env }}
    cloud_region: {{ ansible_ec2_instance_identity_document_region }}
    service_namespace: observability
    service_name: vigil-server
    phxi_service_name: vigil
    phxi_service_component: server
    phxi_account_name: {{ account_name }}
    phxi_account_label: {{ account_name }}-{{ platform_env }}
    severity: page