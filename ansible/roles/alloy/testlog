ST=\"$( echo \"${FQDN}\" | sed \"s/ZONE/${availabilityzone}/;s/INSTANCEID/${instanceid}/\" )\"\nlocalip=\"$( ip addr show primary scope global | awk '/inet/ { print $2 }' | cut -d \"/\" -f 1 )\"\nlocaldomain=\"use2.obs.phxi.net\"\necho \"FIXME: Installing aws-cli until packer builds are complete\"\nsnap install aws-cli --classic\nhostedzoneid=\"$( aws ssm get-parameter --name /platform/dns/hosted_zone/id --query \"Parameter.Value\" --output text )\"\nif [ \"${hostedzoneid}x\" == \"x\" ];then\n  echo \"Failed to find ssm parameter for HostedZoneId from (/platform/dns/hosted_zone/id)\"\n  exit 1\nfi\necho \"Inserting route53 hostname A record for ${localname}\"\nchangeset='{\n  \"Changes\": [\n  {\n   \"Action\": \"UPSERT\",\n   \"ResourceRecordSet\": {\n    \"Name\": \"'${USEHOST}'\",\n    \"Type\": \"A\",\n    \"TTL\": 3600,\n    \"ResourceRecords\": [{ \"Value\": \"'${localip}'\" }]\n   }\n  }\n ]\n}'\necho \"aws route53 change-resource-record-sets --hosted-zone-id ${hostedzoneid} --change-batch ${changeset}\"\nawsout=\"$( aws route53 change-resource-record-sets --hosted-zone-id ${hostedzoneid} --change-batch \"${changeset}\" )\"\nif [[ ! \"${awsout}\" =~ \\\"PENDING\\\" ]];then\n  echo \"Error: failed to create hostname A record! changeset was ${changeset}\"\n  echo \"aws response: ${awsout}\"\n  exit 1\nfi\necho \"Success creating record for ${localname}\"\necho \"Sleeping for 15 seconds to ensure record is created before we proceed.. should probably loop checking status instead..\"\nsleep 15\necho \"Setting system hostname to ${USEHOST}\"\nhostnamectl set-hostname ${USEHOST}\necho \"$( date ) installing aws-cli snap\"\nsnap install aws-cli --classic || { echo \"Failed to install aws-cli snap!\"; exit 1; }\necho \"$( date ) copying bootstrap script from s3 url ${S3URL}\"\naws s3 cp ${S3URL} /root/deploy-bootstrap.sh || { echo \"Failed to use awscli to copy bootstrap script from s3!\"; exit 1; }\nif [ ! -f /root/deploy-bootstrap.sh ];then\n  echo \"Missing deploy-bootstrap script after s3 cp from url: ${S3URL}\"\n  exit 1\nfi\nchmod +x /root/deploy-bootstrap.sh\nset -o pipefail\necho \"$( date ) running bootstrap script including roles: ${ROLES}\"\n/root/deploy-bootstrap.sh | tee -a /root/deploy-bootstrap.log || { echo \"Failure running deploy-bootstrap script!\"; exit 1; }\necho \"$( date ) user-data bootstrap script complete\"\nexit 0\n",
