<group name="yara,">
    <rule id="100101" level="10">
        <decoded_as>json</decoded_as>
        <field name="yara.rule">\.+</field>
        <description>YARA rule matched</description>
        <group>yara,</group>
    </rule>

    <rule id="100102" level="12">
        <if_sid>100101</if_sid>
        <field name="yara.rule">glimmer_syscall_pattern</field>
        <description>YARA: Binary with direct syscall networking</description>
        <group>yara,malware,</group>
    </rule>

    <rule id="100103" level="14">
        <if_sid>100101</if_sid>
        <field name="yara.rule">glimmer_stripped_rust_implant</field>
        <description>YARA: High-confidence implant detection</description>
        <group>yara,malware,</group>
    </rule>

    <rule id="100104" level="10">
        <if_sid>100101</if_sid>
        <field name="yara.rule">glimmer_crypto_profile</field>
        <description>YARA: P-256 ECDH + AES-GCM crypto profile</description>
        <group>yara,malware,</group>
    </rule>

    <rule id="100105" level="8">
        <if_sid>100101</if_sid>
        <field name="yara.rule">glimmer_serde_config</field>
        <description>YARA: Serde config with crypto artifacts</description>
        <group>yara,</group>
    </rule>

    <rule id="100106" level="6">
        <if_sid>100101</if_sid>
        <field name="yara.rule">glimmer_high_entropy_small_elf</field>
        <description>YARA: High entropy small ELF binary</description>
        <group>yara,</group>
    </rule>

    <rule id="100200" level="6">
        <if_sid>80700</if_sid>
        <field name="audit.key">network_connect</field>
        <description>Auditd: Network connect syscall detected</description>
        <group>audit,network,</group>
    </rule>
</group>

<group name="suricata,glimmer,">
    <!-- Glimmer-specific parent rule - evaluated first -->
    <rule id="100300" level="10">
        <if_sid>86601</if_sid>
        <field name="alert.signature">GLIMMER</field>
        <description>Suricata: $(alert.signature)</description>
        <group>suricata,glimmer,</group>
    </rule>

    <rule id="100301" level="12">
        <if_sid>100300</if_sid>
        <field name="alert.signature_id">1000001</field>
        <description>Suricata: C2 POST with data/token form pattern</description>
        <group>suricata,glimmer,malware,</group>
    </rule>

    <rule id="100302" level="10">
        <if_sid>100300</if_sid>
        <field name="alert.signature_id">1000002</field>
        <description>Suricata: C2 session cookie with hex node ID</description>
        <group>suricata,glimmer,malware,</group>
    </rule>

    <rule id="100303" level="10">
        <if_sid>100300</if_sid>
        <field name="alert.signature_id">1000003</field>
        <description>Suricata: POST to root with Connection close</description>
        <group>suricata,glimmer,malware,</group>
    </rule>

    <rule id="100304" level="10">
        <if_sid>100300</if_sid>
        <field name="alert.signature_id">1000004</field>
        <description>Suricata: C2 server empty nginx response</description>
        <group>suricata,glimmer,malware,</group>
    </rule>

    <rule id="100305" level="14">
        <if_sid>100300</if_sid>
        <field name="alert.signature_id">1000005</field>
        <description>Suricata: Repeated beacon pattern detected</description>
        <group>suricata,glimmer,malware,</group>
    </rule>

    <!-- General trojan catch-all - excludes Glimmer-specific alerts -->
    <rule id="100310" level="10">
        <if_sid>86601</if_sid>
        <field name="alert.category">Network Trojan</field>
        <field name="alert.signature" negate="yes">GLIMMER</field>
        <description>Suricata: Network Trojan - $(alert.signature)</description>
        <group>suricata,malware,</group>
    </rule>
</group>
